# ─── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ─── Next.js build output ───────────────────────────────────────────────────────
.next/
out/

# ─── TypeScript incremental build cache (generated — never commit) ─────────────
tsconfig.tsbuildinfo
*.tsbuildinfo

# ─── Environment variables ──────────────────────────────────────────────────────
# Never commit secrets. Copy .env.example → .env.local to get started.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── OS / editor artifacts ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Deployment ─────────────────────────────────────────────────────────────────
.vercel/

# ─── Future Spring Boot backend (monorepo) ──────────────────────────────────────
# Uncomment when backend/ directory is added:
# backend/target/
# backend/.gradle/
# backend/build/